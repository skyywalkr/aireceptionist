# Asterisk & ARI Configuration
ARI_URL=http://127.0.0.1:8088
ARI_USER=asterisk
ARI_PASS=secret
ARI_APP_NAME=ai_receptionist
PJSIP_TRUNK_NAME=trunk-provider
ASTERISK_SOUNDS_DIR=/var/lib/asterisk/sounds/custom

# OpenAI Configuration
ENABLE_AI=true
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ElevenLabs Configuration (Optional - for premium TTS)
ELEVENLABS_API_KEY=...

# Pricing & Margins
PRICING_MARGIN=1.3  # 30% margin on top of API costs
MINIMUM_CHARGE_PER_CALL=0.15  # Minimum $0.15 per call
